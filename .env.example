OPENROUTER_API_KEY=sk-or-v1-...

# Clock mode: "real_time" or "simulated"
CLOCK_MODE=simulated

# Server
PORT=8000

# Database paths
DOMAIN_DB_PATH=domain.db
CHECKPOINT_DB_PATH=agent_checkpoints.db

# Monitor settings
ATTENTION_THRESHOLD=0.6
TICK_INTERVAL_SECONDS=60

# Logging: "human" or "json"
LOG_FORMAT=human

# Suppression window after analyst approval (FR-LOOP-02)
SUPPRESSION_TICKS=3
SUPPRESSION_MULTIPLIER=0.2

# LLM models — OpenRouter format (provider/model); swap anytime in this file
SLM_MODEL=google/gemma-4-31b-it
LLM_MODEL=qwen/qwen3.6-plus

# Optional: cap output tokens per call (leave unset to let the model decide)
# LLM_MAX_TOKENS=4096

# ── Deep evaluation (make eval-deep) ──────────────────────────────────────────
# Judge model for deepeval LLM-as-judge metrics (OpenRouter format)
# Should be a capable reasoning model; kept separate from agent models
EVAL_JUDGE_MODEL=qwen/qwen3-plus

# Langfuse observability — traces + scores per eval run
# Leave unset to run eval-deep offline (tracer no-ops gracefully)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
